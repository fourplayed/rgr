{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "outDir": "./dist",
    "rootDir": "./src",
    "lib": ["ES2022", "DOM"],
    "paths": {
      "@rgr/shared/types": ["./src/types"],
      "@rgr/shared/types/*": ["./src/types/*"]
