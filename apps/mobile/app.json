{
  "expo": {
    "name": "RGR Fleet",
    "slug": "rgr-mobile",
    "version": "2.0.2",
    "orientation": "portrait",
    "scheme": "rgr",
    "icon": "./src/assets/icon.png",
    "userInterfaceStyle": "automatic",
    "splash": {
      "backgroundColor": "#000030"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.rgr.fleetmanager",
      "buildNumber": "12",
      "infoPlist": {
        "NSCameraUsageDescription": "Camera is used to scan QR codes on fleet assets",
        "NSLocationWhenInUseUsageDescription": "Location is captured during asset scans for fleet tracking"
      }
    },
    "android": {
      "package": "com.rgr.fleetmanager",
      "adaptiveIcon": {
        "foregroundImage": "./src/assets/icon.png",
        "backgroundColor": "#000030"
      }
    },
    "plugins": [
      "expo-router",
      "expo-font",
      "expo-secure-store",
      [
        "expo-camera",
        {
          "cameraPermission": "Camera is used to scan QR codes on fleet assets"
        }
      ],
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Location is captured during asset scans"
        }
      ]
    ]
  }
}
